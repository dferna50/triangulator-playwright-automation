      ],
      "canBeCreatedBy": [
        "triangulator_admin"
      ]
    },
    "institution_admin": {
      "displayName": "Institution Admin",
      "permissions": [
        "user_management",
        "institution_config"
      ],
      "canBeCreatedBy": [
        "triangulator_admin",
        "institution_admin"
      ],
      "institutionRestriction": "own_institution_only"
    },
    "reviewer": {
      "displayName": "Reviewer",
      "permissions": [
        "review_courses",
        "view_reports"
      ],
      "canBeCreatedBy": [
        "triangulator_admin",
        "institution_admin"
      ],
      "institutionRestriction": "own_institution_only"
    }
