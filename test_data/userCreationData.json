  "validationRules": {
    "email": {
      "required": true,
      "format": "email",
      "unique": true,
      "maxLength": 255
    },
    "firstName": {
      "required": true,
      "minLength": 1,
      "maxLength": 50
    },
    "lastName": {
      "required": true,
      "minLength": 1,
      "maxLength": 50
    },
    "institution": {
      "required": true,
      "mustExist": true
    },
    "role": {
      "required": true,
      "mustBeValid": true,
      "respectPermissions": true
    }
  },
